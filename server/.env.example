# LLM Configuration
# Set these to enable the AI Dungeon Master (otherwise falls back to mock)

# API key / auth token
LLM_API_KEY=your-api-key-here

# Base URL of an OpenAI-compatible API (the server appends /chat/completions)
# Examples:
#   OpenAI:    https://api.openai.com/v1
#   LiteLLM:   https://your-proxy.example.com
#   Local:     http://localhost:8080/v1
LLM_BASE_URL=https://api.openai.com/v1

# Model identifier
LLM_MODEL=gpt-4o-mini
